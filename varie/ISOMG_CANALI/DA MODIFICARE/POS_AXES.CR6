

{----------------------- ATTRIBUZIONE POSIZIONE ASSI PER ESEGUIRE LAVORAZIONE ----------------------}

{---------------------------------------------------------------------------------------------------}
{---------------- L'uso di R763 e R764 č copiato dall'ultima DIAMANT (CNC v2.101) ------------------}
{-- ATTENZIONE : nella DIAMANT č corretto nella COMET NO: viene compensata l'inversione dal DRILL --}
{---------------------------------------------------------------------------------------------------}

{****** ATTENZIONE: DENTRO QUESTA ROUTINE NON E' POSSIBILE USARE I PARAMETRI R400 *****}

N1 IF (R673==0) JMP [CONTINUA]
N2 L<SNGCNT.CR6>

{ Gestione assi PH

{Per semplicitŕ appoggio la gestione su par.R liberi (non le R400, ATTENZIONE!)
N3 R60=0 R61=0

{Multipezzo : PH entrambi fuori ingombro
N4 IF (R569==0) R60=1                   {PH fuori da collisioni
N5 IF (R569==0) R61=1                   {PH fuori da collisioni

{Pendolare Dinamico : solo l'asse di zona fuori ingombro, l'altro posiziona se serve
N6 IF (R569==1) IF (R648==1) R60=1 		{P fuori da collisioni
N7 IF (R569==1) IF (R648==2) R61=1		{H fuori da collisioni

N10 IF(R60>0.5) L <WAIT_P_AVAILABLE_CH0.CR6>
N11 IF(R61>0.5) L <WAIT_H_AVAILABLE_CH0.CR6>

N14 IF (R60==1) IF (R61==0) G0 G53 P=R380					{P fuori da collisioni
N15 IF (R60==0) IF (R61==1) G0 G53 H=R381					{H fuori da collisioni
N16 IF (R60==1) IF (R61==1) G0 G53 P=R380 H=R381			{PH fuori da collisioni


[CONTINUA]
N21 IF (R569==0) R668=0		{Azzero memoria conferma operatore ergo solo in multipezzo (in pendo l'azzera il PC)
N22 IF (R569==0) IF (R513==1) $M191	{Chiudi i ripari (per modifiche ergonomico in multipezzo)

N23 $M101							{Start Trasportatore Trucioli

N24 L <SNGCNT.CR6>
N25 G90								{Movimenti assoluti, ci pensa la SR a girare tutto


{identificazione TAVOLA da muovere SX/DX/ENTRAMBE}
N26 IF (R569==0) [TAVSING]
N27 IF (R569==1) [TAVDOUB]

[TAVSING]
N30 IF (R535==2) R683=R536+92		{tavola Sx esclusa, muovi solo TAV.DX}
N31 IF (R535==2) [CONTPOS]
N32 IF (R536==2) R683=R535+90		{tavola Dx esclusa, muovi solo TAV.SX}
N33 IF (R536==2) [CONTPOS]
N34 R683=R535+94					{tavole funzionanti insieme: BASTA UNA SOLA SELEZIONE}
N35 JMP [CONTPOS]

[TAVDOUB]
N37 IF (R527==1) R683=R535+90		{macchina a SX, muove TAV.SX}
N38 IF (R527==2) R683=R536+92		{macchina a DX, muove TAV.DX}


[CONTPOS]
N41  IF(R649 == 1)  JMP [SET_VAR]    {maschiatura rigida attiva}
N42  IF(R6093 == 1) JMP [SET_VAR]    {tastatura attiva}
{---- Eseguo il comando di rotazione solo se varia ----}	
N43  IF(R495<R241) JMP [STARTROT]	{Almeno il senso di rotazione varia	
N44  IF(R495>R241) JMP [STARTROT]

N45  IF(R496<R242) JMP [STARTROT]	{Almeno la velocitŕ varia
N46  IF(R496>R242) JMP [STARTROT]
N47  JMP [SET_VAR]


[STARTROT]	
N50  IF (R242 <  1) JMP [APPVAL]		{Velocitŕ 0 : non impostate per errore  
N51  IF (R241 == 0) M03 S=R242			{Senso di Rotazione Orario} 
N52  IF (R241 == 1) M04 S=R242			{Senso di Rotazione Antiorario} 

[SET_VAR]
N53  R495=R241
N54  R496=R242

N55 IF(R559==1) R495=-1    {se oltremisura resetto le var R  per corretta gestione oltremisura}
N56 IF(R559==1) R496=-1    {se oltremisura resetto le var R8 per corretta gestione oltremisura}



[APPVAL]
{Correzioni da battuta di precisione}
N60  IF (R890== 0) R2160=0       JMP [ENDCORBP]  { Battuta di precisione assente }
N61  IF (R340== 0) R2160=0       JMP [ENDCORBP]  { Nessuna correzione richiesta }
