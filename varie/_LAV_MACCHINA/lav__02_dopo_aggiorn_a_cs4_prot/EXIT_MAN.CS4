N2200 {lavorazione su faccia 2}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]

[FACE3_C2]
N2300 {lavorazione su faccia 3}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]

[FACE4_C2]
N2400 {lavorazione su faccia 4}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
