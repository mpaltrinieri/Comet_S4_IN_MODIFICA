{BLOCCA ESECUZIONE SUL CH0 FINO A QUANDO IL CH1 NON DECIDE DI FARLO RIPARTIRE}
{R6869 = Sincronizza il CH0 con il CH1}
{R6869 = 2 libera il CH0 da attesa lanciata da CH1}

[WAIT_SYN_CON_CH1]
N100 IF(R6869>1.9) IF(R6869<2.1) JMP [FINE]
N200 L <SNGCNT.CS4>
N300 G4 F0.1
N400 JMP [WAIT_SYN_CON_CH1]

[FINE]
N1000 L <SNGCNT.CS4>
N1100 R6869=0   {reset liberato dal canale 1}
N1200 RET
