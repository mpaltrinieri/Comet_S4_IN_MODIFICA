{N6010  IF(R400<0.5) IF((V6003/1)>(R6490-R7187)) G00 G53 Y=(R6490-R7187) {Y allontana ut. da ingombro con W}
{N6015  R401=2                                 {causale per attesa avanzamento tavole FATM}
{N6016  L MOV_TAV.CS4
