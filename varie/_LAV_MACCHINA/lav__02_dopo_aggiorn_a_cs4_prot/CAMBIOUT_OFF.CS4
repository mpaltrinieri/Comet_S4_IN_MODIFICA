
{*********** CAMBIO UTENSILE SIMU-X **************}



N10000 IF(LTF(%%V4091)==R611) JMP [NO_TC]             {non simulare cambio utensile}
 

N10101 IF(R611==  1)  SETMESSAGE 1; TOOLCHANGE_PLACE_01		{ Messaggio inizio cambioutensili }
N10102 IF(R611==  2)  SETMESSAGE 1; TOOLCHANGE_PLACE_02		{ Messaggio inizio cambioutensili }		
N10103 IF(R611==  3)  SETMESSAGE 1; TOOLCHANGE_PLACE_03		{ Messaggio inizio cambioutensili }
