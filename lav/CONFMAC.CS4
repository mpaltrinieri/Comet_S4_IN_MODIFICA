R710=10       {Spazio lasciato tra ingombro pezzo e punta mandrino  | Space between workpiece edge and spindle nose

R712=(600000*V4065*V4065/60)      {Accelerazione veloce asse X  (originale 600000)  | X axis rapid acceleration (original 600000)
R713=(180000*V4065*V4065/60)      {Accelerazione veloce asse Y  (originale 180000)  | Y axis rapid acceleration (original 180000)
R714=(360000*V4065*V4065/60)      {Accelerazione veloce asse Z  (originale 360000)  | Z axis rapid acceleration (original 360000)
R715=(30000*V4065*V4065/60)       {Accelerazione lenta assi X Y Z (SLOWACC)         | X Y Z axes slow acceleration 
R716=(80000*V4065*V4065/60)       {Accelerazione media assi X Y Z (MIDACC)          | X Y Z axes medium acceleration 

R717=0        {Numero TAU dopo i quali allarme | TAU number before alarm 
R718=2000     {(Default :2000) Asse A: Velocitŕ di posizionamento a 90° in riferimento | A Axis: Positioning speed to 90° in reference 

R720=25000    {(Default:25000) Velocitŕ asse W in contemporanea nel magazzino        | W axis speed in simultaneity in tool magazine 
R721=18000    {(Default:18000) Velocitŕ veloce per posizionamento morse motorizzate  | Fast speed for motorized clamps positioning

R724=1.0      {(Default:0.5) Tolleranza per cui una morsa č considerata da non spostare  | Tolerance within which clamp considered not to be moved 

R726=13000    {(Default:13000) Velocitŕ Ricerca Morse : Asse X in ricerca libera                  | Clamps Search Speed: X Axis in free search 
R727=10000    {(Default:10000) Velocitŕ Ricerca Morse : Asse X abbandona micro - scendi su camme  | Clamps Search Speed: X Axis clear microswitch - descend on cams
R728=500      {(Default:500) Velocitŕ Ricerca Morse : Asse X ricerca micro - ritorno su camme     | Clamps Search Speed: X axis find microswitch - return on cams

R735=1        {Endurance : se =1 abilita il movimento morse della quota di R736               | Endurance: if =1 enables movements of clamps of R736 position 
R736=100      {Endurance : Quota di scostamento morse in mm verso dx abilitata                | Endurance: Clamps deviation position in mm towards RH enabled 
R737=0        {Ciclo di endurance abilitato (1=normale, 2=fiera) N.B.: fare una sola ripetizione | Endurance cycle enabled (1=normal, 2=proud), N.B.: to execute with single repetition 
R738=8        {(Default:6sec) Endurance : tempo di attesa dopo ripari bassi                   | Endurance : wait time after guards down 
R739=1        {Parametro per aggiustamento calcolo tempo ciclo in simulato                    | Parameter to adjust cycle time calculation in simulated mode

R746=1.0      {(Default:0.5 sec) Temporizzo l'attesa chiusura sicura fra morse in riposizionamento             | Time wait for safe closing between clamps in repositioning 

R756=2000     {(Default:2000)  Asse X - Accelerazione bassa per pos. morse con morsa    | X axis - Slow acceleration for clamps pos. with clamp
R757=8000     {(Default:8000)  Asse X - Accelerazione alta  per pos. morse senza morsa  | X axis - Fast acceleration for clamps pos. without clamp
R758=20000    {(Default:30000) Asse X - Velocita bassa      per pos. morse con morsa    | X axis - Slow speed for clamps pos. with clamp 
R759=80000    {(Default:80000) Asse X - Velocita alta       per pos. morse senza morsa  | X axis - Fast speed for clamps pos. without clamp 

R760=R760     {offset asse X      | X axis offset 
R761=R761     {offset asse Y      | Y axis offset 
R762=R762     {offset asse Z      | Z axis offset 

R763=R763     {offset Y mandrino  | spindle Y offset 
R764=R764     {Offset Z mandrino  | spindle Z offset 
R765=R765     {Offset X mandrino  | spindle X offset 

R767=3.0      {Delta max posizionamento morse per controllo (mm) | Max clamps positioning delta for check (mm)

R787=6000     {Jerk per MIDACC con curve cubiche  | MIDACC  Jerk for cubic S curves 
R788=2000     {Jerk per SLOWACC con curve cubiche | SLOWACC Jerk for cubic S curves 
R789=20000    {Jerk per FASTACC con curve cubiche in semiautomatico | FASTACC Jerk for cubic S curves in test mode
R790=0.3      {Tolleranza nella discriminazione di quota raggiunta ASSI                             | Tolerance in discrimination of position reached AXES
R791=10       {(Default:10) R_RIT_SFRENO1 :  RICH_ABIL          >> Sbloccaggio Zimmer               | RICH_ABIL                 >>  Pneumatic brakesRelease
