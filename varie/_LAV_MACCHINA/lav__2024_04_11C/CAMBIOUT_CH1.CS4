{N5500  L SEQ_C_UT.CS4                         {cambia sequenza se dep in fila inferiore e prel in quella superiore}
{N5510  IF(R6034<0.5) G0 G53 Y=(R6490-R7187)   {Y allontana ut. da ingombro con W}
{N5515  R401=2                                 {causale per attesa avanzamento tavole FATM}
{N5516  L MOV_TAV.CS4
{N5520  IF(R6034>0.5) G00 G53 Z=R6491          {Z mandrino in posizione di prelievo}
N5530  L WAIT_W_CH1.CS4                           {attesa fine movimento asse indipendente}
{N5540  $M05                                   {verifica mandrino fermo}
{N5550  IF(R6034>0.5) G00 G53 Y=(R6490-R7187)  {Y allontana ut. da ingombro con W}
{N5560  IF(R6034<0.5) G00 G53 Z=R6491          {Z mandrino in posizione di prelievo}
{N5570  G00 G53 Y=(R6490-R7185)                {Y mandrino in posizione di fuori ingombro da utensile}
{N5580  $M50                                   {sblocca utensile su mandrino}
{N5590  G01 G53 F=R7180 Y=R6490                {Y mandrino in posizione di prelievo}
{N5600  $M06 T(FTL(R611))
{N5610  $M51                                   {blocca pinza mandrino}
{N5620  G01 G53 F=R7180 Z=(R6491+R7186)        {Z uscita lenta dalla pinza}
{N5630  G00 G53 Z=R349                         {mandrino fuori ingombro morse in Z, conferma prelievo eseguito}
{N5640  G00 G53 Y=R7182                        {mandrino fuori ingombro magazzino in Y}
N5642  IF(R7510>1.5) IF(R575>0.5)  JMP [R_D_20]
{N5650  R68=R393                               {carica posizione asse W finecorsa negativo}
