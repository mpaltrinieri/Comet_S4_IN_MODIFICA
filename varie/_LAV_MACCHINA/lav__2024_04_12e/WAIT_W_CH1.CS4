{***** FINE MOVIMENTO ANTICIPATO ASSE W *****}

    {{{N100 <WAT:FRE;W>
    {{{N110 G303 W
    {{{N120 G312 OFF W

N100 IF(R450<0.5) JMP [AUTO]
N110 R6865=1+2+0          {sincronizza canale 0,1}
N120 L <SYNCNC_CH1.CS4>   {Sincronizzazione livello 0 ***************************}
N130 JMP [FINE]

[AUTO]
N200 L <SNGCNT_CH1.CS4>
N210 R6869=2              {libera l'attesa sul CH0 da CH1}

[FINE]
N300 RET
