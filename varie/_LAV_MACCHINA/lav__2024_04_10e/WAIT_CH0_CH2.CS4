{BLOCCA ESECUZIONE SUL CH2 FINO A QUANDO IL CH0 NON DECIDE DI FARLO RIPARTIRE}
{R6867 = Sincronizza il CH2 con il CH0}
{R6867 = 4 libera il CH2 da attesa lanciata da CH0}

[WAIT_SYN_CON_CH0]
N100 IF(R6867>3.9) IF(R6867<4.1) JMP [FINE]
N200 L <SNGCNT_CH2.CS4>
N300 G4 F0.1
N400 JMP [WAIT_SYN_CON_CH0]

[FINE]
N1000 L <SNGCNT_CH2.CS4>
N1100 R6867=0   {reset libera canale 2}
N1200 RET
