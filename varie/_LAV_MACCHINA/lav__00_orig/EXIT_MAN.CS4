[FACE6_C1]
N1600 {lavorazione su faccia 6 (Lato inferiore con testina)}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      Y=-R335
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      RET


