{BLOCCA ESECUZIONE SUL CH1 FINO A QUANDO IL CH0 NON DECIDE DI FARLO RIPARTIRE}
{R6866 = Sincronizza il CH1 con il CH0}
{R6866 = 2 libera il CH1 da attesa lanciata da CH0}

[WAIT_SYN_CON_CH0]
N100 IF(R6866>1.9) IF(R6866<2.1) JMP [FINE]
N200 L <SNGCNT_CH1.CS4>
N300 G4 F0.1
N400 JMP [WAIT_SYN_CON_CH0]

[FINE]
N1000 L <SNGCNT_CH1.CS4>
N1100 R6866=0   {reset libera canale 1}
N1200 RET
