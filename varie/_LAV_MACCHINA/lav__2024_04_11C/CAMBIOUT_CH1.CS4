[FINE_1]
N9010  L SNGCNT_CH1.CS4

{N9200  TL=(R507)                              {aggiorna lunghezza utensile}
{N9210  TR=(R508)                              {aggiorna raggio utensile}
{N9220  R6054=R554                             {memorizza dimensione utensile}

{//////////////////////////////////////////////////////////////////////////////////////////////////

{***** Sincronizzazione tra PLC e CNC *****}
{[CKLENGHT]
{N11000 IF(ABS(R507-R619) < 0.001) JMP [CKRADIUS]
{N11005 L SNGCNT_CH1.CS4
{N11010 G4 F0.1 
{N11015 JMP [CKLENGHT]

{[CKRADIUS]
{N11100 IF(ABS(R508-R620) < 0.001) JMP [CKACTOOL]
{N11105 L SNGCNT_CH1.CS4
{N11110 G4 F0.1
{N11115 JMP [CKRADIUS]

{[CKACTOOL]
{N11200 IF(R610==R611) JMP [LROK]
{N11205 L SNGCNT_CH1.CS4
{N11210 G4 F0.1
{N11215 JMP [CKACTOOL]

{[LROK]
{N11300 L SNGCNT_CH1.CS4
{N11340 L <CALC_ZOUT.CS4>        {calcolo delle variabili ZOUT di uscita ottimizzata dalle lavorazioni}
N11350 JMP [FINE_3]

{//////////////////////////////////////////////////////////////////////////////////////////////////

[FINE_2]                        {nessun prelievo fatto (R611=0) e' stato solo depositato un utensile in magazzino
{N12240 G00 G53 Z=R349 $M51     {mandrino a Z max e blocca pinza mandrino}
{N12250 G00 G53 Y=R7182         {Y: mandrino fuori ingombro magazzino}

{R6360==21: CARICO AUTOMATICO (prima parte) solo deposito utensile attuale nel magazzino (lasciar mag.ut.aperto) 
N12430 IF(ABS(R6360-21)<0.5) JMP [FINE_3]

{ N12630  R68=R393                             {carica posizione asse W finecorsa negativo}
N12640  L MOVIND_W_CH1.CS4                     {muove W al finecorsa negativo}
{ N12650  G00 G53 Z=R349                       {mandrino fuori ingombro morse in Z}
N12660  L WAIT_W_CH1.CS4                       {attesa fine movimento asse indipendente}

{ N12670  $M73                                 {deposito finito}

N12990 JMP [FINE_3]

{//////////////////////////////////////////////////////////////////////////////////////////////////

[SIMUX_OFFL]
{N40100 L <CAMBIOUT_OFF.CS4> 
N40130 JMP [FINE_3]

{//////////////////////////////////////////////////////////////////////////////////////////////////

[FINE_3]
{N90120 L FASTACC.CS4
N90130 L SNGCNT_CH1.CS4

{ N91310 R6866=0 R6867=0          {reset variabili di sincronizzazione da CH0 verso CH1, CH2}
{ N91320 R6869=0 R6870=0          {reset variabili di sincronizzazione da CH1, CH2 verso CH0}
{ N91330 L <RES_CAUSALE_MC.CS4>   {reset causale per eseguire il cambio utensili}

N99120 RET
