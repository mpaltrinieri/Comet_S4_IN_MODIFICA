L CONFTIME.CS4

{*************************************************************
{********************** Dati di Collaudo *********************
{*************************************************************

R3950=0       {pausa di test delle rototraslazioni attivate dalla POS_AXES.CS4

R693=0        { Azzero PWD di collaudo ogni inizio attivitŕ        | Reset test PWD at each activity start 

{#356=1       {Area #356 : messa a 1 abilita la scrittura con comandi dello slave da tastiera esterna | Area #356 : set to 1 enables writing with slave commands from external keypad

{ @1 -> individua velocemente le differenze tra le versioni "X" e "PH" | @1 -> rapid identification of differences between "X" and "PH" versions

{*************************************************************
{******************* Dati di inizializzazione ****************
{*************************************************************

G66                     { Abilita curve a S | Enable S curves
R748=32                 { Definizione curve a S: 2=standard; 16=curve ad S; 32=curve cubiche | Define S curves: 2=standard; 16=S curves; 32=S curves cubic 
(%V6082.3=(FTI(R748)))  { Imposta curve ad S | Set S-curves  

R4=150.720    { Versione S/W CNC | CNC S/W version
R5=7.457      { Versione S/W sistema operativo CNC: Costantino

R99=0         {Tipo macchina (inserire uno dei seg. valori):  | Machine type (enter one of the following values):
              {3311 = Comet S4 Morse Motorizzate              | 3311 = Comet S4 Motorized Clamps
              {3310 = Comet S4 Base                           | 3310 = Comet S4 Base

R189=100      {FEED FORWARD Spindle              | FEED FORWARD Spindle 

(V4149=0.020) {Accelerazione per volantini | Acceleration for handwheel
R7896=0.020   {Accelerazione assi X,Y,A,C con volantino | Acceleration X,Y,A,C axis with handwheel
R7897=0.055   {Accelerazione asse Z con volantino | Acceleration Z axis with handwheel

R500=60       { Frequenza refrigerante utensili     | Tool coolant frequency
R501=520      { Massima altezza profilo o morse     | Maximum high piece or clamp 
R504=15       { Tutte le lubriche attive di default | All lube points active by default 
R520=0        { Reset parametro profilo di mantenimento morse chiuse }

R5957=1       { =0 esegue l'approccio tangenziale sul lato lungo, =1 esegue l'approccio tangenziale sul raggio raccordo (Figure Asola, Tasca)

