{N5070  IF(R400>0.5) $M77                     {verifica possibilita' di prelievo utensile}
{N5080  $M74                                  {Ciclo di prelievo utensile in corso}
{N5085  $M73                                  {deposito utensile eseguito}
{N5090  L SNGCNT_CH1.CS4                      {impedisce che R68 venga letta in anticipo}
{N5100  R68=R6495                             {carica posizione asse W per prelievo utensile}
N5110  L MOVIND_W_CH1.CS4                     {muove W a quota di cambio utensile}
{N5130  IF(R400>0.5) G00 G53 Z=R349 A=R6492 C=R6493 {asse Z a Zout, AC in posizione}
{N5140  IF(R400<0.5) G00 G53 A=R6492 C=R6493  {AC in posizione}
N5150  IF(R611>R6501) JMP [PRE_SUP]
N5160  IF(R611<R6501) JMP [PRE_INF]

