      [5FACES]
      IF (R340 >  0) IF (R203 == 1) R690=R690+(V11006.(FTI(R3047))){applica correzione asse X} 
      IF (R340 >  0) IF (R203 == 2) R690=R690+(V11006.(FTI(R3047))){applica correzione asse X} 
      IF (R340 >  0) IF (R203 == 3) R690=R690+(V11006.(FTI(R3047))){applica correzione asse X} 
      IF (R340 >  0) IF (R203 == 4) R690=R690-(V11006.(FTI(R3047))){applica correzione asse X} 
      IF (R340 >  0) IF (R203 == 5) R690=R690+(V11006.(FTI(R3047))){applica correzione asse X} 
      IF (R340 >  0) IF (R203 == 6) R690=R690+(V11006.(FTI(R3047))){applica correzione asse X} 

      IF (R341 >  0) IF (R203 == 1) R691=R691-(V11006.(FTI(R3048))){applica correzione asse Y} 
