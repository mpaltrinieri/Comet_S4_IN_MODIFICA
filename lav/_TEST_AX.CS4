{ TEST MOVIMENTAZIONE ASSI MORSE V1-V12   (RICAVATO DA POSMORS.CS4;  CHIAMA MOVEMORS.CS4)

N1  $M00 { VERIFICARE TUTTO PRIMA DI ESEGUIRE 


{******************************* ATTENZIONE ***********************************}
{******** Non usare i parametri R400-R404 : riservati alla MOVMORS.CS4 ********}
{******************************************************************************}

{VERIFICA ASSI RIFERITI

{N100 L RIFASSI.CS4 
N200 JMP [AX_RIF] 

N100 IF(R6051>0.5) IF(R6052>0.5)   JMP [AX_RIF] 

N110 IF(R6051<0.5) L RIFASSI.CS4  

N120 IF(R6052>0.5)   JMP [AX_RIF] 

N210 $M64					{abilita assi per riferimento
N220 L RIFMORSE.CS4
N230 $M65					{Conferma assi riferiti

[AX_RIF] 
{N200 $M00


{******************************************************************************}
{ IMPOSTAZIONI GENERICHE DI MACCHINA (VERIFICARE I DATI SUCCESSIVI!!!)
{******************************************************************************}

R470=R473=1	
{R693=0	{31247 Azzero PWD di collaudo ogni inizio attivitŕ }

N5 R532=12      { R_NUM_MORSE }
N6 R525=6       { R_NUM_MORSE_SX }
N7 R526=6       { R_NUM_MORSE_DX }
N8 R523=255      { R_INTERAX_MORSE_SX: Dist. Min Morse Sx}
N9 R524=255      { R_INTERAX_MORSE_DX: Dist. Min Morse Dx}
N10 R509=0      { R_GESTMORS_OPER }
N11 R555=216.75      { R_MIN_SX_ZONA_MORSE }
N12 R556=3537      { R_MAX_SX_ZONA_MORSE }

N17 R240=434.98      { Z fuori ingombro  }
N18 R251=434.98      { Z scavalcamento morse }

{******************************************************************************}
{ IMPOSTAZIONI DEL CICLO DI TEST 
{******************************************************************************}
{R4200	CONTATORE MOVIMENTI ESEGUITI

R4220=5	{TIPO DI FUNZIONAMENTO
R4221=1000	{100 spostamento rispetto alla posiz iniziale
R4222=48000	{(MAX:48000) Velocitŕ di spostamento morse 
R4223=2.0	{0	PAUSA in sec tra i movimenti
R4224=300	{200	distanza fra le morse
R4225=100	{0	distanza di sicurezza tra morse e limiti zone (R555 R556 R557 R558)
R4226=0	{attesa conferma $M00
R4227=1	{ripete rif assi slave lmd

R4201=1     {0 0 1 1=Abilita movimento asse V1 
R4202=1     {0 0 1 1=Abilita movimento asse V2 
R4203=1     {0 1 1 1=Abilita movimento asse V3 
R4204=1     {0 1 1 1=Abilita movimento asse V4 
R4205=1     {0 1 1 1=Abilita movimento asse V5 
R4206=1     {1 1 1 1=Abilita movimento asse V6 
R4207=1     {0 0 0 1=Abilita movimento asse V7 
R4208=1     {0 0 0 1=Abilita movimento asse V8 
R4209=1     {0 0 0 1=Abilita movimento asse V9 
R4210=1     {0 0 0 1=Abilita movimento asse V10
R4211=1     {0 0 0 1=Abilita movimento asse V11
R4212=1     {0 0 0 1=Abilita movimento asse V12

{******************************************************************************}

[START]
N100 IF(R4227<0.5) JMP [TEST]

N210 $M64					{abilita assi per riferimento
N220 L RIFMORSE.CS4                 
N230 $M65					{Conferma assi riferiti

[TEST]
N310 IF((ABS(R4220-1))<0.2) JMP [START1]
N320 IF((ABS(R4220-2))<0.2) JMP [START2]
N320 IF((ABS(R4220-3))<0.2) JMP [START3]
N320 IF((ABS(R4220-4))<0.2) JMP [START4]
N320 IF((ABS(R4220-5))<0.2) JMP [START5]
N330 G4 F0.1
N340 L <SNGCNT.CS4>
N350 JMP [TEST]

{******************************************************************************}

