{*** CALCOLO POSIZIONE ASSI PER SCAVALCAMENTO LATERALE: ***}
{**** verifica se ingombra di piu' l'utensile o la struttura testina ***}
{R335 = quota assoluta per scavalcamento laterale relativa alla punta utensile passata da DRILL}
{R619 = lunghezza utensile}
{R620 = raggio utensile}
{R689 = posizione comandata asse A}
{R699 = posizione comandata asse C}
{R5015 = Offset Y testina}
{R5016 = Offset Z testina}
{R554 = Dimensione testina per uscita da pezzo}

N10  IF(R204<0.5) JMP [FINE]  {esci se non utensile testina}
N20  IF(R250>1.5) IF(R691>(R6265-0.1)) IF(R691<(R6265+0.1)) JMP [FINE]  {esci se ha fatto prima disimpegno o lav. in stesso punto}

N100 R4500 = R620*COS(R689)+R619*SIN(R689)  {proiezione utensile in direzione Y}
N110 R4501 = (R554-R5015)*COS(R689)         {proiezione parte bassa struttura testina in direzione Y}

N200 IF(R4500>=R4501) R6261=R335+R620*COS(R689)*SIN(R699)     {il contributo lunghezza utensile è già considerato in CAM_EMMEGI.CS4}

N210 IF(R4500<R4501) R6261=R335+(R554-R5015)*COS(R689)*SIN(R699)   {contributo struttura testina}

N220 L <SNGCNT.CS4>
N230 R4502=(R691-R6261)               {appoggio quota di scavalcamento laterale profilo rispetto all'origine}
N240 R4503=-R330*SIN(R689)*SIN(R699)  {proiezione della R330 nella direzione Y}
N250 L<SNGCNT.CS4>
N260 IF(ABS(R4502)>=ABS(R4503)) R6262=R4502  {appoggio quota di scavalcamento laterale profilo rispetto all'origine}
N270 IF(ABS(R4502)<ABS(R4503))  R6262=R4503  {appoggio quota di scavalcamento laterale profilo rispetto all'origine uguale alla proiezione del disimpegno}

N280 IF(R5017==0)   R6262=R634  {con testina che lavora in testa non deve fare scavalcamento laterale}
N290 IF(R5017==180) R6262=R634  {con testina che lavora in coda non deve fare scavalcamento laterale}

{verifica se la proiezione del disimpegno è maggiore della quota di scavalcamento laterale testina}

[FINE]
N300 RET
