
{------------------------ GESTIONE USCITA UTENSILE DA LAVORAZIONE ---------------------}

N01 L <CALC_YOUT.CS4>
N05 IF(R585>0.5) JMP [ASSOLUTO]
N10 IF (R250 == 0) [CASO1] { Lavorazione successiva su piano o con utensile diverso
N20 IF (R250 == 1) [CASO2] { Lavorazione successiva su stesso piano con scavalcamento morse
N30 IF (R250 == 2) [CASO3] { Lavorazione successiva su stessa faccia senza scavalcamento morse (DISIMPEGNO CALCOLATO DA CAMPLUS)
N40 IF (R250 == 3) [CASO4] { Lavorazione successiva su stessa faccia in stesso punto
N50 JMP [FINE]

{-------------- Lavorazione successiva su piano o con utensile diverso ------------}
[CASO1]
N1000 IF (R203 == 1) [FACE1_C1]
N1010 IF (R203 == 2) [FACE2_C1]
N1020 IF (R203 == 3) [FACE3_C1]
N1030 IF (R203 == 4) [FACE4_C1]
N1040 IF (R203 == 5) [FACE5_C1]
N1050 IF (R203 == 6) [FACE6_C1]
N1060 JMP [FINE]


[FACE1_C1]
N1100 {lavorazione su faccia 1}
      M9 G0 G40
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253
      JMP [FINE]

[FACE2_C1]
N1200 {lavorazione su faccia 2}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]

[FACE3_C1]
N1300 {lavorazione su faccia 3}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]

[FACE4_C1]
N1400 {lavorazione su faccia 4}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]

[FACE5_C1]
N1500 {lavorazione su faccia 5}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]

[FACE6_C1]
N1600 {lavorazione su faccia 6 (Lato inferiore con testina)}
      M9 G0 G40
      Z=R330
      <DTC : OFF>
      R621=0
      Y=-R335
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]


{-------------- Lavorazione successiva su stesso piano con scavalcamento morse ----------}
[CASO2]
N2000 IF (R203 == 1) [FACE1_C2]
N2010 IF (R203 == 2) [FACE2_C2]
N2020 IF (R203 == 3) [FACE3_C2]
N2030 IF (R203 == 4) [FACE4_C2]
N2040 IF (R203 == 5) [FACE5_C2]
N2050 IF (R203 == 6) [FACE6_C2]
N2060 JMP [FINE]


[FACE1_C2]
N2100 {lavorazione su faccia 1}
      M9 G0 G40
      <DTC : OFF>
      R621=0
      G59 X0 Y0 Z0
      G0 G53 D0 Z=R254
      IF (R254 < R349) [FINE]
      Y=R253 
      JMP [FINE]

