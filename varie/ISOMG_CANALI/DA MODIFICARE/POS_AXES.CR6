      IF (R340 > 99) $M184                         {errore indice tastatura}
      IF (R341 <  0) $M184                         {errore indice tastatura}
      IF (R341 > 99) $M184                         {errore indice tastatura}
      IF (R342 <  0) $M184                         {errore indice tastatura}
      IF (R342 > 99) $M184                         {errore indice tastatura}
      IF (R340 >  0) R3047=400+((R340-1)*2)        {calcolo indice appoggio correzione asse X} 
