{BLOCCA ESECUZIONE SUL CH0 FINO A QUANDO IL CH2 NON DECIDE DI FARLO RIPARTIRE}
{R6870 = Sincronizza il CH0 con il CH2}
{R6870 = 4 libera il CH0 da attesa lanciata da CH2}

[WAIT_SYN_CON_CH2]
N100 IF(R6870>3.9) IF(R6870<4.1) JMP [FINE]
N200 L <SNGCNT.CS4>
N300 G4 F0.1
N400 JMP [WAIT_SYN_CON_CH2]

[FINE]
N1000 L <SNGCNT.CS4>
N1100 R6870=0   {reset liberato dal canale 2}
N1200 RET
