%

R473=1
N120 L FASTACC.CS4

R400=25000  {vel    85000 = 3000rpm
R401=R392   {R392	 // Quota di finecorsa positivo dell'asse W
R402=R393   {R393	 // Quota di finecorsa negativo dell'asse W
R403=0      {0=ciclo infinito,   1 = 1 movimento

R406=1.0    {PAUSA 


[START]
N310 G00 G53 W=R401
N315 G04 F=R406
N320 L SNGCNT.CS4

N410 G00 G53 W=R402
N415 G04 F=R406
N420 L SNGCNT.CS4

N430 IF(R403>0.5) $M00

N490 JMP [START]

N500 RET


