{***** FINE MOVIMENTO ANTICIPATO ASSE W *****}

    {{{N100 <WAT:FRE;W>
    {{{N110 G303 W
    {{{N120 G312 OFF W

N100 IF(R450<0.5) JMP [AUTO]
N110 R6865=1+2+0          {sincronizza canale 0,1}
N120 L <SYNCNC.CS4>       {Sincronizzazione livello 0 ***************************}
N130 JMP [FINE]

[AUTO]
N200 L <WAIT_CH1_CH0.CS4>      {attesa che il CH1 liberi il CH0}

[FINE]
N300 RET
